<style>
/* 1. Basic Variables (Ye zaroori hain colors ke liye) */
:root {
  --primary: #6366f1;
  --primary-hover: #4f46e5;
  --bg: #f8fafc;
  --card-bg: #ffffff;
  --text-main: #1e293b;
  --text-muted: #64748b;
  --border: #e2e8f0;
}

/* 2. Page Setup */
body {
  background-color: var(--bg);
  font-family: 'Poppins', sans-serif;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  margin: 0;
}

/* 3. Form Container */
.update-container {
  width: 100%;
  max-width: 450px;
  padding: 20px;
}

.update-card {
  background: var(--card-bg);
  padding: 35px;
  border-radius: 20px;
  box-shadow: 0 10px 25px rgba(0,0,0,0.08);
  border: 1px solid var(--border);
}

.update-card h3 {
  margin-bottom: 25px;
  color: var(--text-main);
  font-size: 22px;
  text-align: center;
}

/* 4. Inputs & Labels */
.form-group {
  margin-bottom: 20px;
}

.form-group label {
  display: block;
  font-size: 14px;
  font-weight: 600;
  color: var(--text-muted);
  margin-bottom: 8px;
}

input {
  width: 100%;
  padding: 12px 15px;
  border: 1.5px solid var(--border);
  border-radius: 10px;
  font-size: 15px;
  color: var(--text-main);
  transition: 0.3s;
  box-sizing: border-box; /* Padding se width na badhe */
}

input:focus {
  outline: none;
  border-color: var(--primary);
  box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
}

/* 5. Button */
.btn-update {
  width: 100%;
  padding: 14px;
  background: var(--primary);
  color: white;
  border: none;
  border-radius: 10px;
  font-size: 16px;
  font-weight: 600;
  cursor: pointer;
  transition: 0.3s;
  margin-top: 10px;
}

.btn-update:hover {
  background: var(--primary-hover);
  transform: translateY(-2px);
}

/* Back Link */
.back-link {
  display: block;
  text-align: center;
  margin-top: 20px;
  color: var(--text-muted);
  text-decoration: none;
  font-size: 14px;
}
.back-link:hover {
  text-decoration: underline;
}
</style>

<div class="update-container">
  <div class="update-card">
    <h3>Update Book</h3>
    
    <form action="/faculty/update-book/<%= book._id %>" method="POST">
      
      <div class="form-group">
        <label>Book Title</label>
        <input type="text" name="title" value="<%= book.title %>" required>
      </div>

      <div class="form-group">
        <label>Author Name</label>
        <input type="text" name="author" value="<%= book.author %>" required>
      </div>

      <div class="form-group">
        <label>Available Quantity</label>
        <input type="number" name="qty" value="<%= book.availableQty %>" required>
      </div>

      <button type="submit" class="btn-update">Save Changes</button>
      
      <a href="/faculty/dashboard" class="back-link">Cancel and Go Back</a>
    </form>
  </div>
</div>